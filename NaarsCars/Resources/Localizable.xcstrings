    "admin_remove_admin_confirmation": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to remove admin status from this user? They will lose access to admin features."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que deseas quitar el estado de administrador a este usuario? Perderá el acceso a las funciones de administración."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 사용자의 관리자 권한을 해제하시겠습니까? 관리 기능에 대한 접근 권한을 잃게 됩니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc chắn muốn xóa quyền quản trị viên của người dùng này? Họ sẽ mất quyền truy cập các tính năng quản trị."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要移除此用户的管理员身份吗？他们将失去对管理功能的访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要移除此用戶的管理員身份嗎？他們將失去對管理功能的存取權限。"
          }
        }
      }
