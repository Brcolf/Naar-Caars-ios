    "messaging_leave_conversation_confirmation" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to leave this conversation? You can still see the message history but won't receive new messages."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ВҝEstГЎs seguro de que deseas salir de esta conversaciГіn? PodrГЎs ver el historial de mensajes pero no recibirГЎs nuevos mensajes."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "мқҙ лҢҖнҷ”м—җм„ң лӮҳк°ҖмӢңкІ мҠөлӢҲк№Ң? л©”мӢңм§Җ кё°лЎқмқҖ кі„мҶҚ ліј мҲҳ мһҲм§Җл§Ң мғҲ л©”мӢңм§ҖлҠ” л°ӣмқ„ мҲҳ м—ҶмҠөлӢҲлӢӨ."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BбәЎn cГі chбәҜc chбәҜn muб»‘n rб»қi cuб»ҷc trГІ chuyб»Үn nГ y? BбәЎn vбә«n cГі thб»ғ xem lб»Ӣch sб»ӯ tin nhбәҜn nhЖ°ng sбәҪ khГҙng nhбәӯn Д‘Ж°б»Јc tin nhбәҜn mб»ӣi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "зЎ®е®ҡиҰҒзҰ»ејҖжӯӨеҜ№иҜқеҗ—пјҹжӮЁд»Қз„¶еҸҜд»ҘжҹҘзңӢж¶ҲжҒҜеҺҶеҸІпјҢдҪҶдёҚдјҡж”¶еҲ°ж–°ж¶ҲжҒҜгҖӮ"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "зўәе®ҡиҰҒйӣўй–ӢжӯӨе°Қи©ұе—ҺпјҹжӮЁд»Қз„¶еҸҜд»ҘжҹҘзңӢиЁҠжҒҜжӯ·еҸІпјҢдҪҶдёҚжңғж”¶еҲ°ж–°иЁҠжҒҜгҖӮ"
