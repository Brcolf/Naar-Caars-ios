    "guidelines_before_you_begin": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Before you begin, please review and accept our community guidelines."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de comenzar, por favor revisa y acepta nuestras directrices de la comunidad."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시작하기 전에 커뮤니티 가이드라인을 검토하고 동의해 주세요."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trước khi bắt đầu, vui lòng xem xét và chấp nhận các hướng dẫn cộng đồng của chúng tôi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开始之前，请查看并接受我们的社区准则。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開始之前，請查看並接受我們的社區準則。"
          }
        }
      }
    },
