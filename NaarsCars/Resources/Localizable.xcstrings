    "admin_approve_confirmation": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to approve this user? They will be able to access all app features."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que deseas aprobar a este usuario? Podrá acceder a todas las funciones de la aplicación."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 사용자를 승인하시겠습니까? 모든 앱 기능에 접근할 수 있게 됩니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc chắn muốn phê duyệt người dùng này? Họ sẽ có thể truy cập tất cả tính năng của ứng dụng."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要批准此用户吗？他们将能够访问所有应用功能。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要批准此用戶嗎？他們將能夠存取所有應用程式功能。"
          }
        }
      }
    },
