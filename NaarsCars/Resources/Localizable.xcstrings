    },
    "%@ %@": {
      "comment": "A label that indicates a message is being replied to. The text inside the parentheses is a placeholder for the name of the user who sent the original message.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ %2$@"
          }
        }
      }
    },
    "%@ %lld": {
      "comment": "A section header that lists the reaction type followed by the count of how many people reacted with that type.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ %2$lld"
          }
        }
      }
    },
    "%@ → %@": {
      "comment": "A one-line view showing the origin and destination IATA codes of a flight.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ → %2$@"
