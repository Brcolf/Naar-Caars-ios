    "profile_confirm_deletion_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete your account including all rides, favors, messages, reviews, and Town Hall posts. Active requests you've claimed will be reopened for others. This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Esto eliminará permanentemente tu cuenta, incluyendo todos los viajes, favores, mensajes, reseñas y publicaciones del Town Hall. Las solicitudes activas que hayas reclamado se reabrirán para otros. Esta acción no se puede deshacer."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "계정이 영구적으로 삭제되며 모든 라이드, 부탁, 메시지, 리뷰, Town Hall 게시글이 삭제됩니다. 수락한 활성 요청은 다른 사람에게 다시 열립니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Điều này sẽ xóa vĩnh viễn tài khoản của bạn bao gồm tất cả các chuyến đi, giúp đỡ, tin nhắn, đánh giá và bài đăng Town Hall. Các yêu cầu đang hoạt động mà bạn đã nhận sẽ được mở lại cho người khác. Không thể hoàn tác."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "这将永久删除您的账户，包括所有搭车、帮忙、消息、评价和Town Hall帖子。您已接受的活跃请求将重新开放给其他人。此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "這將永久刪除您的帳戶，包括所有搭車、幫忙、訊息、評價和Town Hall貼文。您已接受的活躍請求將重新開放給其他人。此操作無法撤銷。"
          }
        }
      }
    },
