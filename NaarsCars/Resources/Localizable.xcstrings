    "messaging_leave_conversation_confirmation": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to leave this conversation? You can still see the message history but won't receive new messages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que deseas salir de esta conversación? Podrás ver el historial de mensajes pero no recibirás nuevos mensajes."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 대화에서 나가시겠습니까? 메시지 기록은 계속 볼 수 있지만 새 메시지는 받을 수 없습니다."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc chắn muốn rời cuộc trò chuyện này? Bạn vẫn có thể xem lịch sử tin nhắn nhưng sẽ không nhận được tin nhắn mới."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要离开此对话吗？您仍然可以查看消息历史，但不会收到新消息。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要離開此對話嗎？您仍然可以查看訊息歷史，但不會收到新訊息。"
          }
        }
      }
    },
