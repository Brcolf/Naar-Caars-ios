            "state": "new",
            "value": "%1$@ filter%2$@"
          }
        }
      }
    },
    "%@, %@": {
      "comment": "An accessibility label that combines the title and value of the stat card.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@, %2$@"
          }
        }
      }
    },
    "%@: %@, %@": {
      "comment": "A card displaying a user's name, a value, and a category. The category is followed by a comma and a space, then the user's name, followed by a comma and a space, and finally the value.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@: %2$@, %3$@"
          }
        }
      }
    },
    "%@%@, %@, %@": {
      "comment": "A row in a list of notifications, displaying a title, a body (if available), a timestamp, and an unread indicator. The title and timestamp are read aloud together, with the unread indicator providing additional context.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@%2$@, %3$@, %4$@"
          }
        }
      }
    },
    "%lld": {
      "comment": "A badge displaying the number of pending approvals.",
      "isCommentAutoGenerated": true
    },
    "%lld / 500": {
