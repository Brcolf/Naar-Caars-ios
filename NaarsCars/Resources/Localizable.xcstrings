      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to Naar's Cars! Please review these guidelines to ensure our community remains safe, supportive, and helpful."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Bienvenido a Naar's Cars! Por favor revisa estas directrices para asegurar que nuestra comunidad siga siendo segura, solidaria y útil."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Naar's Cars에 오신 것을 환영합니다! 커뮤니티가 안전하고 서로 돕는 환경을 유지할 수 있도록 가이드라인을 검토해 주세요."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chào mừng đến với Naar's Cars! Vui lòng xem xét các hướng dẫn này để đảm bảo cộng đồng của chúng ta luôn an toàn, hỗ trợ và hữu ích."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "欢迎来到Naar's Cars！请查看这些准则，以确保我们的社区保持安全、互助和乐于助人。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歡迎來到Naar's Cars！請查看這些準則，以確保我們的社區保持安全、互助和樂於助人。"
          }
        }
      }
